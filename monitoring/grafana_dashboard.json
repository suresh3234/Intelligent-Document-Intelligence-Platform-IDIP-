{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Semantic Cache Hit Rate",
      "type": "gauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "sum(rate(idip_cache_hits_total[5m])) / (sum(rate(idip_cache_hits_total[5m])) + sum(rate(idip_cache_misses_total[5m])))",
          "legendFormat": "Hit Rate (5m Rolling)",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "RAG Query Volume by Cache Status",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "sum(rate(idip_queries_total[1m])) by (cached)",
          "legendFormat": "{{cached}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Model Inference Latency (95th Percentile)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(idip_inference_duration_seconds_bucket[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Celery Background Queue Depth",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "idip_queue_depth",
          "legendFormat": "{{queue_name}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "title": "Data Feature & Concept Drift Scores",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-datasource"
          },
          "editorMode": "code",
          "expr": "idip_drift_score",
          "legendFormat": "{{feature_name}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.15
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "title": "RAGAS Weekly LLM Quality Scores",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-datasource"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres-datasource"
          },
          "editorMode": "code",
          "rawSql": "SELECT timestamp AS time, faithfulness, answer_relevancy, context_precision, context_recall FROM llm_eval_reports ORDER BY timestamp ASC",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {},
          "max": 1.0,
          "min": 0.0
        }
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["idip", "mlops", "monitoring"],
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "IDIP LLM Quality & Operational Metrics",
  "version": 1
}
